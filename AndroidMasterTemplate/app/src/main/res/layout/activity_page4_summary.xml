<?xml version="1.0" encoding="utf-8"?>
<!-- activity_page4_summary.xml — Final Summary + Database Results -->
<!-- TODO: EXAM_MODIFY — Adjust layout based on what data you're showing -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/white">

    <!-- ── Welcome Header ────────────────── -->
    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Summary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <!-- ── Stats / Aggregate Info ─────────── -->
    <TextView
        android:id="@+id/tvStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#e8f5e9"
        android:padding="10dp"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:text="Stats loading..."
        android:layout_marginBottom="12dp"/>
    <!-- TODO: EXAM_MODIFY — change bg color and font as needed -->

    <!-- ── Results Label ─────────────────── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="All Records:"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>
    <!-- TODO: EXAM_MODIFY — change label -->

    <!-- ── ListView (fills remaining height) -->
    <ListView
        android:id="@+id/lvResults"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:dividerHeight="1dp"
        android:divider="#e0e0e0"/>

    <!-- ── Bottom Navigation Buttons ──────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/btnPrev"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="← Back"
            android:layout_marginEnd="4dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <Button
            android:id="@+id/btnRestart"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="＋ New"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Logout"
            style="@style/Widget.MaterialComponents.Button.TextButton"/>
    </LinearLayout>

</LinearLayout>