<?xml version="1.0" encoding="utf-8"?>
<!-- activity_page2_input.xml — Main Input Form -->
<!-- TODO: EXAM_MODIFY — Rename all hints and labels to your domain -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ── Page Header ────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 2: Enter Details"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>
        <!-- TODO: EXAM_MODIFY — Page title -->

        <!-- ── Full Name ──────────────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Full Name"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etFullName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Age (Numeric) ─────────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Age"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Notes (Multiline) ─────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Notes (optional)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:maxLines="4"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Spinner (Dropdown) ─────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Category:"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>
        <!-- TODO: EXAM_MODIFY — Rename label -->

        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/spinner_border"
            android:padding="8dp"/>
        <!-- TODO: EXAM_MODIFY — If spinner_border drawable not available, remove background line -->

        <!-- ── SeekBar (Score) ───────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Score: (0-100)"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>
        <!-- TODO: EXAM_MODIFY — Rename label and range -->

        <SeekBar
            android:id="@+id/seekBarScore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvSeekBarValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Score: 0"
            android:layout_marginBottom="16dp"/>

        <!-- ── Date Picker ────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnPickDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pick Date"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnPickTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pick Time"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvSelectedDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Date: Not selected"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvSelectedTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Time: Not selected"
            android:layout_marginBottom="16dp"/>

        <!-- ── CheckBoxes ─────────────────────── -->
        <CheckBox
            android:id="@+id/cbTerms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="I accept the Terms and Conditions"
            android:layout_marginBottom="4dp"/>
        <!-- TODO: EXAM_MODIFY — Rename or remove -->

        <CheckBox
            android:id="@+id/cbNewsletter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Subscribe to newsletter"
            android:layout_marginBottom="16dp"/>
        <!-- TODO: EXAM_MODIFY — Rename or remove -->

        <!-- ── RadioGroup ─────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Priority:"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>
        <!-- TODO: EXAM_MODIFY — Rename label -->

        <RadioGroup
            android:id="@+id/rgPriority"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rbLow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Low"
                android:layout_marginEnd="12dp"/>
            <!-- TODO: EXAM_MODIFY -->

            <RadioButton
                android:id="@+id/rbMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medium"
                android:layout_marginEnd="12dp"/>
            <!-- TODO: EXAM_MODIFY -->

            <RadioButton
                android:id="@+id/rbHigh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="High"/>
            <!-- TODO: EXAM_MODIFY -->
        </RadioGroup>

        <!-- ── Image Placeholder ──────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Profile Image:"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <ImageView
            android:id="@+id/ivProfileImage"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@android:drawable/ic_menu_gallery"
            android:background="#e0e0e0"
            android:scaleType="centerCrop"
            android:layout_marginBottom="16dp"
            android:contentDescription="Profile Image"/>
        <!-- TODO: EXAM_MODIFY — rename id, size, description -->

        <!-- ── Navigation Buttons ─────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnPrev"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="← Back"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <Button
                android:id="@+id/btnNext"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Next →"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>