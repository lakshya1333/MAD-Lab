<?xml version="1.0" encoding="utf-8"?>
<!-- activity_page5_extra.xml — Optional 5th Page Layout -->
<!-- TODO: EXAM_MODIFY — Replace with your required components -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/white">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Step 5: Extra Page"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>
    <!-- TODO: EXAM_MODIFY — page title -->

    <!-- TODO: EXAM_MODIFY — Add your UI components here
         Copy-paste any components from Page 2's XML as needed:
         - EditText blocks
         - Spinner block
         - SeekBar block
         - CheckBox block
         - RadioGroup block
    -->

    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="(Add your content here)"
        android:gravity="center"
        android:textColor="#999999"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnPrev"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="← Back"
            android:layout_marginEnd="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <Button
            android:id="@+id/btnFinish"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Finish ✓"/>
    </LinearLayout>

</LinearLayout>