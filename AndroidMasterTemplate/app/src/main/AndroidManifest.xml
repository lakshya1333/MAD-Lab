<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.androidmastertemplate">

    <!-- ===== PERMISSIONS ===== -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AndroidMasterTemplate">

        <!-- ===== PAGE 1: Authentication / Login (Main Entry) ===== -->
        <activity
            android:name=".Page1_Auth"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ===== PAGE 2: Main Input Form ===== -->
        <activity
            android:name=".Page2_Input"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ===== PAGE 3: Details / Secondary Input ===== -->
        <activity
            android:name=".Page3_Details"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ===== PAGE 4: Summary / Results Display ===== -->
        <activity
            android:name=".Page4_Summary"
            android:exported="false" />

        <!-- ===== PAGE 5: Extra ===== -->
        <activity
            android:name=".Page5_Extra"
            android:exported="false" />

        <!-- ===== MAIN ACTIVITY (If still used) ===== -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

    </application>

</manifest>