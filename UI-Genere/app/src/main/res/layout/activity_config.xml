<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnConfigBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Back"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:textColor="#3F51B5"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/tvAppTitleHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="App: My Application"
                android:textColor="#757575"
                android:textSize="12sp"
                android:layout_gravity="center_vertical"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvConfigTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configure Screen 1"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#3F51B5"
            android:layout_marginBottom="20dp"/>

        <EditText
            android:id="@+id/etScreenPurpose"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Step A: Screen Purpose (e.g. Login)"
            android:inputType="text"
            android:layout_marginBottom="15dp"/>

        <Spinner
            android:id="@+id/spLayoutType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="15dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step C: Add Components"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Spinner
                android:id="@+id/spComponentType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>

            <EditText
                android:id="@+id/etQuantity"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="1"
                android:gravity="center"/>
        </LinearLayout>

        <EditText
            android:id="@+id/etComponentLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Label (e.g. 'Select Gender')"
            android:layout_marginTop="5dp"/>

        <EditText
            android:id="@+id/etComponentOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Options (comma separated, for Spinner/Radio)"
            android:visibility="gone"
            android:layout_marginTop="5dp"/>

        <Button
            android:id="@+id/btnAddToList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Add to Screen"
            android:layout_gravity="end"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_marginTop="5dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Current Screen Components:"
            android:textStyle="italic"
            android:layout_marginTop="15dp"/>

        <TextView
            android:id="@+id/tvAddedList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:padding="10dp"
            android:text="Empty"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnConfigNext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Screen &amp; Go Next"
            android:backgroundTint="#3F51B5"
            android:textColor="#FFFFFF"
            android:padding="12dp"/>

    </LinearLayout>
</ScrollView>
