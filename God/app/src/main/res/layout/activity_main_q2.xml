<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Items and Quantity"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <!-- Item 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">
        <CheckBox
            android:id="@+id/cbPizza_q2"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Pizza" />
        <EditText
            android:id="@+id/etPizzaQty_q2"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:hint="Qty"
            android:inputType="number" />
    </LinearLayout>

    <!-- Item 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">
        <CheckBox
            android:id="@+id/cbBurger_q2"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Burger" />
        <EditText
            android:id="@+id/etBurgerQty_q2"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:hint="Qty"
            android:inputType="number" />
    </LinearLayout>

    <!-- Item 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">
        <CheckBox
            android:id="@+id/cbPasta_q2"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Pasta" />
        <EditText
            android:id="@+id/etPastaQty_q2"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:hint="Qty"
            android:inputType="number" />
    </LinearLayout>

    <Button
        android:id="@+id/btnOrder_q2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Place Order" />

</LinearLayout>