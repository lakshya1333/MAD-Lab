<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_horizontal">

    <EditText
        android:id="@+id/etNumber_q1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter a number"
        android:inputType="number" />

    <RadioGroup
        android:id="@+id/rgChecker_q1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp">

        <RadioButton
            android:id="@+id/rbPrime_q1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Prime Checker" />

        <RadioButton
            android:id="@+id/rbSquare_q1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Perfect Square Checker" />
    </RadioGroup>

    <Button
        android:id="@+id/btnCheck_q1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Check"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvResult1_q1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btnNext1_q1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Next Page"
        android:layout_marginTop="32dp" />

</LinearLayout>